<h1>New expense</h1>

<%= form_with model: @expense do |f| %>
  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :amount %>
    <%= f.number_field :amount, step: 0.01 %>
  </div>

  <div>
    <%= f.label :date %>
    <%= f.date_select :date %>
  </div>

  <div>
    <%= f.label :month %>
    <%= f.date_select :month, discard_day: true %>
  </div>

  <div>
    <%= f.label :expense_type %>
    <%= f.select :expense_type, Expense.expense_types.keys.map { |k| [k.humanize, k] } %>
  </div>

  <div>
    <%= f.submit "Save" %>
  </div>
<% end %>
